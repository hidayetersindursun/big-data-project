# Copy to .env (already auto-generated by ./setup.sh if missing)
#
# HOST_IP  = the address your browser / external Kafka client connects TO.
#            On a laptop:   localhost
#            On EC2 / VM:   the public IP (e.g. 3.72.105.132)
#
# HOST_DNS = optional DNS name (e.g. ec2-3-72-105-132.eu-central-1.compute.amazonaws.com)
#            leave as localhost if you don't use one.

HOST_IP=localhost
HOST_DNS=localhost
